<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  <template class="UnitySearchAppResults" parent="AdwBin">
    <property name="child">
      <object class="AdwPreferencesGroup">
        <property name="title" translatable="yes">Applications</property>
        <property name="header-suffix">
          <object class="GtkToggleButton" id="show_more">
            <property name="label" translatable="yes">Show More</property>
            <style>
              <class name="flat"/>
              <class name="show-more"/>
            </style>
          </object>
        </property>
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">12</property>
            <child>
              <object class="GtkFlowBox" id="flow_first">
                <property name="selection-mode">browse</property>
                <property name="homogeneous">true</property>
                <property name="min-children-per-line">5</property>
                <property name="max-children-per-line">5</property>
                <property name="column-spacing">12</property>
                <property name="row-spacing">12</property>
              </object>
            </child>
            <child>
              <object class="GtkRevealer" id="revealer">
                <property name="child">
                  <object class="GtkFlowBox" id="flow_rest">
                    <property name="selection-mode">none</property>
                    <property name="homogeneous">true</property>
                    <property name="min-children-per-line">5</property>
                    <property name="max-children-per-line">5</property>
                    <property name="column-spacing">12</property>
                    <property name="row-spacing">12</property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
